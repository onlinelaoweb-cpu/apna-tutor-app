# Get your key from https://console.anthropic.com (API billing is separate from your claude.ai subscription)
ANTHROPIC_API_KEY=your_key_here

# Optional: enables a natural cloud voice instead of the browser's built-in voice.
# From https://console.cloud.google.com - create a project, enable the "Cloud Text-to-Speech API",
# then create an API key restricted to that API. Leave blank to keep using the browser's voice.
GOOGLE_TTS_API_KEY=

# Railway sets PORT automatically - only needed for local testing if you want a custom port
# PORT=3000